[Unit]
Description=Arizona Power Outage Explorer Dashboard Web Service
After=network.target

[Service]
Type=simple
# Replace 'pi' with your actual Linux user running the service
User=pi
# Replace with the absolute path to your cloned repository
WorkingDirectory=/home/pi/az-power-outage-archive
# Replace path to the start script
ExecStart=/home/pi/az-power-outage-archive/scripts/start_dashboard.sh
Restart=on-failure
RestartSec=5

# Optional Custom Environment Variables
Environment=HOST=0.0.0.0
Environment=PORT=5000
Environment=FLASK_DEBUG=false
Environment=DATA_DIR=data
Environment=AUTO_REFRESH_SECONDS=60

[Install]
WantedBy=multi-user.target
