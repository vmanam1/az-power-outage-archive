# Arizona Power Outage Explorer Configuration Options

# The IP address the Flask server should bind to (0.0.0.0 allows LAN access)
HOST=0.0.0.0

# The local port to run the web server on
PORT=5000

# Enables Flask debug mode when set to true (not recommended for production/Pi deploy)
FLASK_DEBUG=false

# Root directory of utility providers outage snapshots
DATA_DIR=data

# Polling frequency in seconds for checking new local JSON files
AUTO_REFRESH_SECONDS=60
